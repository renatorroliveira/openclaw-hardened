# Default to Windows NVIDIA GPU preset (Docker Desktop + WSL2).
# Linux NVIDIA users: override with COMPOSE_PROFILES=nvidia OPENCLAW_PRESET=nvidia
# Apple Silicon users: override with COMPOSE_PROFILES= OPENCLAW_PRESET=apple-silicon
COMPOSE_PROFILES=windows-nvidia
OPENCLAW_PRESET=windows-nvidia

# Gateway auth token (required for LAN bind mode). Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=changeme

# Ollama options
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_KV_CACHE_TYPE=q4_K_M

# AWS Bedrock Configuration (only used when OPENCLAW_PRESET=bedrock)
# AWS_BEDROCK_REGION=us-west-2
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
