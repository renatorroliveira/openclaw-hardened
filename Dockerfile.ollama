# ==============================================================================
# Dockerfile.ollama — Custom Ollama image with model preloading
# ==============================================================================

FROM ollama/ollama:latest

# Install curl for healthcheck and readiness polling
RUN apt-get update && apt-get install -y --no-install-recommends curl vim \
    && rm -rf /var/lib/apt/lists/*

# Copy and set up the entrypoint script
COPY scripts/ollama-entrypoint.sh /usr/local/bin/ollama-entrypoint.sh
COPY .env /usr/local/bin/.env
RUN chmod +x /usr/local/bin/ollama-entrypoint.sh

COPY models /root/models

# OLLAMA_HOST is set via docker-compose.yml for visibility/configurability

EXPOSE 11434

# Persistent model storage
VOLUME ["/root/.ollama"]

ENTRYPOINT ["/usr/local/bin/ollama-entrypoint.sh"]
